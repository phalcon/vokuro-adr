<?xml version="1.0"?>
<ruleset name="Vokuro ADR">
    <description>Vökuró ADR Coding Standards</description>

    <arg name="colors"/>
    <arg value="ps"/>

    <rule ref="PSR12">
        <exclude name="PSR2.Methods.MethodDeclaration.Underscore"/>
        <exclude name="PSR1.Files.SideEffects.FoundWithSymbols"/>
    </rule>

    <file>../src</file>
    <file>../public/index.php</file>
    <file>migrations</file>
    <file>seeds</file>
</ruleset>
