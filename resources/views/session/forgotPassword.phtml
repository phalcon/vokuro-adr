<?php

/**
 * @var array                         $messages
 * @var \Vokuro\Contracts\Csrf        $csrf
 * @var \Phalcon\Html\TagFactory      $tag
 * @var \Phalcon\Mvc\Url\UrlInterface $url
 */

use Vokuro\Forms\ForgotPasswordForm;

$form = new ForgotPasswordForm();
$form->setTagFactory($tag);
?>
<h1>Forgot Password?</h1>
<p>Enter your email and we'll send a reset link.</p>

<?php foreach ((array) $messages as $message) { ?>
    <div class="alert"><?= $message ?></div>
<?php } ?>

<form method="post">
    <div class="field">
        <label for="forgot-email-input">Email address</label>
        <?= $form->render('email', [
            'class'       => 'input',
            'id'          => 'forgot-email-input',
            'placeholder' => 'Enter email',
        ]) ?>
    </div>

    <?= $tag->inputHidden('csrf', $csrf->token()) ?>

    <?= $form->render('Send', ['class' => 'btn']) ?>
</form>

<hr>
<?= $tag->aRaw($url->get('session/login'), '&larr; Back to Login') ?>
