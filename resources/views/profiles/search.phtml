<?php

/**
 * @var array                         $result page + query
 * @var \Phalcon\Html\TagFactory      $tag
 * @var \Phalcon\Mvc\Url\UrlInterface $url
 */

use Vokuro\Domain\Page;

/** @var Page $page */
$page  = $result['page'];
$query = '' === $result['query'] ? '' : '&' . $result['query'];

$pill = static fn(bool $on): string => $on
    ? '<span class="pill pill-ok">Yes</span>'
    : '<span class="pill pill-warn">No</span>';
?>
<div class="page-head">
    <h1>Found profiles</h1>
</div>

<div class="actions">
    <?= $tag->aRaw($url->get('profiles'), '&larr; Go Back', ['class' => 'btn-ghost btn']) ?>
    <?= $tag->a($url->get('profiles/create'), 'Create profiles', ['class' => 'btn']) ?>
</div>

<div class="data-table table-scroll">
    <table>
        <thead>
        <tr><th>Id</th><th>Name</th><th>Active?</th><th></th><th></th></tr>
        </thead>
        <tbody>
        <?php foreach ($page->items as $profile) { ?>
            <tr>
                <td class="id"><?= $profile->id ?></td>
                <td class="name"><?= $profile->name ?></td>
                <td><?= $pill($profile->active) ?></td>
                <td><?= $tag->a($url->get('profiles/edit/' . $profile->id), 'Edit', ['class' => 'btn-sm btn-ghost btn']) ?></td>
                <td><?= $tag->a($url->get('profiles/delete/' . $profile->id), 'Delete', ['class' => 'btn-sm btn-danger btn']) ?></td>
            </tr>
        <?php } ?>
        <?php if ($page->items->isEmpty()) { ?>
            <tr><td colspan="5">No profiles are recorded</td></tr>
        <?php } ?>
        </tbody>
    </table>
</div>

<div class="actions">
    <?= $tag->a($url->get('profiles/search?page=' . $page->previous() . $query), 'Previous', ['class' => 'btn-sm btn-ghost btn']) ?>
    <span class="btn-sm btn-ghost btn"><?= $page->current ?> / <?= $page->last ?></span>
    <?= $tag->a($url->get('profiles/search?page=' . $page->next() . $query), 'Next', ['class' => 'btn-sm btn-ghost btn']) ?>
</div>
