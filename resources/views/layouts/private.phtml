/**
 * @var \Phalcon\Html\TagFactory      $tag
 * @var \Phalcon\Mvc\Url\UrlInterface $url
 * @var \Vokuro\Domain\Meta|null      $extras
 * @var string                        $section
 */

$rail = static function (string $to, string $svg, string $label, string $current) use ($tag, $url): string {
    $icon = $svg . '<span class="lbl">' . $label . '</span>';

    return $tag->aRaw(
        $url->get($to),
        $icon,
        ['class' => ($to === $current ? 'is-active' : '')]
    );
};

$icons = [
