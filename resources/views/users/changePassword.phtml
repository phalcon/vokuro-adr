<?php

/**
 * @var array                         $messages field => message
 * @var \Vokuro\Contracts\Csrf        $csrf
 * @var \Phalcon\Html\TagFactory      $tag
 * @var \Phalcon\Mvc\Url\UrlInterface $url
 */

use Vokuro\Forms\ChangePasswordForm;

$form   = new ChangePasswordForm();
$errors = (array) $messages;
$form->setTagFactory($tag);

$error = static fn(string $field): string => isset($errors[$field])
    ? '<div class="field-error">' . $errors[$field] . '</div>'
    : '';
?>
<div class="page-head">
    <h1>Change Password</h1>
</div>

<div class="card">
    <form method="post" action="<?= $url->get('users/changePassword') ?>">
        <div class="field">
            <label for="password">Password</label>
            <?= $form->render('password', ['class' => 'input', 'placeholder' => 'Password']) ?>
            <?= $error('password') ?>
        </div>

        <div class="field">
            <label for="confirmPassword">Confirm Password</label>
            <?= $form->render('confirmPassword', ['class' => 'input', 'placeholder' => 'Confirm Password']) ?>
            <?= $error('confirmPassword') ?>
        </div>

        <?= $tag->inputHidden('csrf', $csrf->token()) ?>
        <?= $error('csrf') ?>

        <?= $tag->inputSubmit('save', 'Change Password', ['class' => 'btn']) ?>
    </form>
</div>
