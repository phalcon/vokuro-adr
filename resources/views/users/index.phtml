<?php

/**
 * @var array                         $result page + profiles
 * @var \Phalcon\Html\TagFactory      $tag
 * @var \Phalcon\Mvc\Url\UrlInterface $url
 */

use Vokuro\Domain\Page;
use Vokuro\Forms\UserSearchForm;
use Vokuro\Infrastructure\View\ProfileSelectData;

/** @var Page $page */
$page = $result['page'];

$form = new UserSearchForm();
$form->setTagFactory($tag);

$pill = static fn(bool $on, string $yes, string $no): string => $on
    ? '<span class="pill pill-warn">' . $yes . '</span>'
    : '<span class="pill pill-ok">' . $no . '</span>';
?>
<div class="page-head">
    <h1>Users</h1>
    <p>Manage who can access Vökuró.</p>
</div>

<div class="actions">
    <?= $tag->a($url->get('users/create'), 'Create Users', ['class' => 'btn']) ?>
</div>

<div class="card">
    <h3>Search users</h3>
    <form method="get" action="<?= $url->get('users/search') ?>">
        <div class="toolbar">
            <?= $form->render('id', ['class' => 'input', 'placeholder' => 'Id']) ?>
            <?= $form->render('name', ['class' => 'input', 'placeholder' => 'Name']) ?>
            <?= $form->render('email', ['class' => 'input', 'placeholder' => 'Email']) ?>
            <?php
            $profileSelect = $tag->inputSelect('', '', ['name' => 'profilesId', 'class' => 'select'])
                ->addPlaceholder('Any profile', '')
                ->fromData(new ProfileSelectData($result['profiles']));
            ?>
            <?= $profileSelect ?>
            <?= $tag->button('Search', ['type' => 'submit', 'class' => 'btn']) ?>
        </div>
    </form>
</div>

<div class="data-table table-scroll">
    <table>
        <thead>
        <tr>
            <th>Id</th><th>Name</th><th>Email</th><th>Profile</th>
            <th>Banned?</th><th>Suspended?</th><th>Confirmed?</th><th></th><th></th>
        </tr>
        </thead>
        <tbody>
        <?php foreach ($page->items as $user) { ?>
            <tr>
                <td class="id"><?= $user->id ?></td>
                <td class="name"><?= $user->name ?></td>
                <td><?= $user->email ?></td>
                <td><?= $user->profileName ?></td>
                <td><?= $pill($user->banned, 'Yes', 'No') ?></td>
                <td><?= $pill($user->suspended, 'Yes', 'No') ?></td>
                <td><?= $pill(!$user->active, 'No', 'Yes') ?></td>
                <td><?= $tag->a($url->get('users/edit/' . $user->id), 'Edit', ['class' => 'btn-sm btn-ghost btn']) ?></td>
                <td><?= $tag->a($url->get('users/delete/' . $user->id), 'Delete', ['class' => 'btn-sm btn-danger btn']) ?></td>
            </tr>
        <?php } ?>
        <?php if ($page->items->isEmpty()) { ?>
            <tr><td colspan="9">No users are recorded</td></tr>
        <?php } ?>
        </tbody>
    </table>
</div>

<div class="actions">
    <?= $tag->a($url->get('users?page=' . $page->previous()), 'Previous', ['class' => 'btn-sm btn-ghost btn']) ?>
    <span class="btn-sm btn-ghost btn"><?= $page->current ?> / <?= $page->last ?></span>
    <?= $tag->a($url->get('users?page=' . $page->next()), 'Next', ['class' => 'btn-sm btn-ghost btn']) ?>
</div>
